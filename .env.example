# Copy this file to .env.local and fill in your own Supabase project values.
# Get these from: Supabase Dashboard -> Project Settings -> API
#
# If these are left unset, the app runs in "guest mode": progress is stored
# only in the browser's localStorage, there is no login, and the Admin Panel
# is unavailable.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
