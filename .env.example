# ============================================================================
# FDE Tracker — environment variables
# ============================================================================
# Copy this file to `.env.local` for local dev, and set the same two variables
# in your Vercel / Netlify dashboard for production. Vite only exposes variables
# that start with VITE_ to the browser (everything else is ignored + unreachable
# from client code, which is why the secret service-role key is NEVER stored here).
#
#   cp .env.example .env.local
#
# NOTE: .env.local is gitignored. Never commit real keys. The "service role"
# key from Supabase is server-side only and must NOT be used here.
# ----------------------------------------------------------------------------

# Required ONLY if you want account mode (Google sign-in, cloud sync, the
# Admin panel, and live shared profiles). The app runs fully in guest mode
# without these — leave them blank to ship the tracker with no backend.

# Your Supabase project URL. Looks like:
#   https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=

# Your Supabase anon/public key (safe to expose to the browser — RLS protects
# your data). Copy it from Supabase Dashboard → Project Settings → API →
# "anon public". It is a JWT that starts with "eyJ...".
VITE_SUPABASE_ANON_KEY=

# ----------------------------------------------------------------------------
# Optional (advanced): override the default OAuth provider labels shown in the
# UI. Usually left empty.
# ----------------------------------------------------------------------------
# VITE_AUTH_PROVIDER_LABEL=Google
