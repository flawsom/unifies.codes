# ============================================================================
# Unifies — environment variables
# ============================================================================
# Sign-in works OUT OF THE BOX: the app ships with a committed public Supabase
# anon key, so "Sign in with Google" is live on any deployment with zero setup.
# Setting VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY below upgrades to YOUR OWN
# Supabase project (the /api/analyze endpoint also reads SUPABASE_URL /
# SUPABASE_ANON_KEY server env — no VITE_ prefix required). All vars optional.
# ----------------------------------------------------------------------------

# --- Optional: account mode (Google sign-in, cloud sync, shared profiles) ---
# Leave these blank to run fully in guest mode (no backend, no accounts).
# Your Supabase project URL, e.g. https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/public key (safe in the browser — RLS protects your data).
# Copy from Supabase Dashboard → Project Settings → API → "anon public".
VITE_SUPABASE_ANON_KEY=

# --- Optional: Unifies AI curriculum analysis (serverless function only) ---
# PRIMARY: Google Gemini FREE API. Get a key at https://aistudio.google.com/apikey
# (no billing required; gemini-2.0-flash has a generous free tier). The key is
# used by /api/analyze and is NEVER exposed to the browser. Without any AI key,
# the app still works using its built-in offline planner.
GEMINI_API_KEY=
# Optionally override the default Gemini model.
# GEMINI_MODEL=gemini-2.0-flash

# FALLBACK: OpenRouter free models (used only if GEMINI_API_KEY is absent).
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optionally override the OpenRouter free model.
# OPENROUTER_MODEL=google/gemma-2-9b-it:free
