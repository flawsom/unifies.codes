# ============================================================================
# Unifies — environment variables
# ============================================================================
# Copy this file to `.env.local` for local dev, and set the same variables
# in your Vercel / Netlify dashboard for production. Vite only exposes variables
# that start with VITE_ to the browser (everything else is ignored + unreachable
# from client code). The Supabase secret/service-role key is NEVER stored here.
#
#   cp .env.example .env.local
#
# NOTE: .env.local is gitignored. Never commit real keys.
# ----------------------------------------------------------------------------

# --- Optional: account mode (Google sign-in, cloud sync, shared profiles) ---
# Leave these blank to run fully in guest mode (no backend, no accounts).
# Your Supabase project URL, e.g. https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/public key (safe in the browser — RLS protects your data).
# Copy from Supabase Dashboard → Project Settings → API → "anon public".
VITE_SUPABASE_ANON_KEY=

# --- Optional: Unifies AI curriculum analysis (serverless function only) ---
# This key is used by the /api/analyze serverless function and is NEVER exposed
# to the browser. Get a FREE key at https://openrouter.ai/keys (no cost on the
# free models). Without it, the app still works using its built-in offline
# planner — it just won't call an LLM.
OPENROUTER_API_KEY=

# Optionally override the free model used by /api/analyze.
# OPENROUTER_MODEL=google/gemma-2-9b-it:free
